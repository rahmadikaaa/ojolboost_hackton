# ============================================================
# OjolBoost MAMS — .dockerignore
# File dan folder yang TIDAK perlu masuk ke Docker image
# ============================================================

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual Environment
venv/
.venv/
env/
.env/

# Test & Dev artifacts
tests/
.pytest_cache/
.coverage
htmlcov/
*.log

# Git
.git/
.gitignore

# Secrets (JANGAN masuk image)
.env
*.pem
*.key
service-account*.json

# IDE
.vscode/
.idea/
*.swp

# Docs
*.md
blueprint.md
CLAUDE.md
